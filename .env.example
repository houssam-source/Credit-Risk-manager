# Credit Risk Management API - Environment Variables

### Production Security Configuration

# API Security Mode (dev | prod)
# In production mode: disables /docs, /redoc, /openapi.json endpoints
API_ENV=prod

# Strong API Key (REQUIRED for production)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-super-secret-key-change-this-in-production

# Server Configuration
API_HOST=127.0.0.1
API_PORT=8001

# CORS Allowed Origins (comma-separated, NO wildcards in production)
# Only add trusted frontend domains
API_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://houssam-source-credit-risk-manager-app.streamlit.app

# Request Size Limit (bytes) - Prevent DoS attacks
MAX_REQUEST_BYTES=262144

# Model Integrity Verification (SHA256 hashes)
# Generate with: python scripts/generate_model_hashes.py
SCALER_SHA256=your-scaler-hash-here
RANDOM_FOREST_SHA256=your-rf-model-hash-here
GRADIENT_BOOSTING_SHA256=your-gb-model-hash-here
NEURAL_NETWORK_SHA256=your-nn-model-hash-here

# Inference Logging (for drift detection)
INFERENCE_LOG_PATH=data/monitoring/inference_window.csv
INFERENCE_LOG_MAX_ROWS=10000
INFERENCE_LOG_PRUNE_EVERY=200
