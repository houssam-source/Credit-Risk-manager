### Credit Risk Management API - environment variables (example)

# Enable "production mode" hardening:
# - disables /docs, /redoc, /openapi.json
# - reduces information returned by /health
API_ENV=prod

# Require API key (when set) via header: X-API-Key
API_KEY=change-me-to-a-strong-secret

# Server bind options
API_HOST=127.0.0.1
API_PORT=8001

# CORS allowed origins (comma-separated)
API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Request size limit (bytes)
MAX_REQUEST_BYTES=262144

# Optional: lock down model artifacts by SHA256
# Generate values with:
#   python scripts/generate_model_hashes.py
SCALER_SHA256=
RANDOM_FOREST_SHA256=
GRADIENT_BOOSTING_SHA256=
NEURAL_NETWORK_SHA256=

